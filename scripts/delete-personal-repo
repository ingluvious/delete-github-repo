#!/bin/bash
set -euo pipefail

OWNER="ingluvious"
REPO="$1"
DELETE_APP_PATH="/Users/ingluvious/Dev - Personal/delete-github-repo/app/delete-repo.py"
VENV_PYTHON="/Users/ingluvious/Dev - Personal/delete-github-repo/.venv/bin/python"

if [ -z "$REPO" ]; then
    echo "Usage: delete-personal-repo <repo>"
    exit 1
fi

if [ -f "$HOME/.config/.env" ]; then
    set -a
    source "$HOME/.config/.env"
    set +a
fi

PROJECT_ROOT="$(dirname "$(dirname "$DELETE_APP_PATH")")"
if [ -f "$PROJECT_ROOT/.env" ]; then
    set -a
    source "$PROJECT_ROOT/.env"
    set +a
fi

"$VENV_PYTHON" "$DELETE_APP_PATH" "$OWNER" "$REPO"
